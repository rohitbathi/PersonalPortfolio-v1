# Google-only LLM config
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
# Voice understanding model used by /api/voice (audio-in -> text).
GEMINI_VOICE_MODEL=gemini-2.5-flash
# Gemini-native voice output model (text-in -> audio-out).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Optional Gemini voice name used with GEMINI_TTS_MODEL
# Try: Aoede, Leda, Kore, Charon, Fenrir, Orus, Zephyr, Puck
GEMINI_VOICE=Kore
# Alias supported:
# GEMINI_VOICE_NAME=Kore

# Optional: force Google voice audio (if true and Gemini returns no audio, request fails)
GEMINI_VOICE_STRICT=false

# Optional: timeout in ms for upstream model calls
LLM_TIMEOUT_MS=12000
# Optional: separate timeout for Gemini TTS (voice output) calls
LLM_TTS_TIMEOUT_MS=30000
# Set either timeout to 0 to disable abort timeout completely

# Optional: override frontend endpoints
VITE_CHAT_API_URL=/api/chat
VITE_VOICE_API_URL=/api/voice

# Optional: local dev API port for npm run dev
LOCAL_API_PORT=3001
